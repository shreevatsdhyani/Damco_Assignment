# Backend Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_SESSION_TOKEN=your_aws_session_token_here
AWS_REGION=us-east-1

# Bedrock Model Configuration
# Sonnet 4.5 (US): us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Haiku 4.5 (US): us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Alternative: Direct Anthropic API (if not using Bedrock)
# ANTHROPIC_API_KEY=your_api_key_here

# Security
SECRET_KEY=change_this_in_production_to_a_secure_random_string
